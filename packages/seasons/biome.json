{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "extends": ["../../biome.json"],
  "files": {
    "ignore": ["demo/", "dist/"]
  },
  "overrides": [
    {
      "include": ["tests/**"],
      "linter": {
        "rules": {
          "style": {
            "noNonNullAssertion": "warn"
          },
          "suspicious": {
            "noExplicitAny": "warn"
          }
        }
      }
    }
  ]
}
