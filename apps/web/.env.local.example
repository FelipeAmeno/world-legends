# Supabase Auth (T060)
# 1. Criar projeto em https://supabase.com
# 2. Copiar Project URL e anon key abaixo
# 3. Renomear este arquivo para .env.local

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Configurar providers no Supabase Dashboard:
# Authentication → Providers → Google → ativar (Client ID + Secret do GCP)
# Authentication → Providers → Apple → ativar (Service ID + Key do Apple Dev)
# Authentication → URL Configuration → Redirect URLs: http://localhost:3000/auth/callback

# PostHog Analytics (T067)
# Criar projeto em https://app.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=phc_your_project_key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Sentry Crash Reporting (T068)
# Criar projeto em https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=https://xxx@o123.ingest.sentry.io/456
NEXT_PUBLIC_SENTRY_ENV=development
NEXT_PUBLIC_SENTRY_RELEASE=1.0.0

# Sentry CLI (para upload de source maps — usar em CI)
SENTRY_AUTH_TOKEN=sntrys_xxx
SENTRY_ORG=world-legends
SENTRY_PROJECT=world-legends-web

# Asset Studio — ferramenta interna (Sprint 43A)
# Allowlist de e-mails autorizados a acessar /dev/asset-studio, separados
# por vírgula. NUNCA prefixar com NEXT_PUBLIC_ — precisa ficar só
# server-side. Ausente/vazio = ninguém autorizado (fail-closed).
ASSET_STUDIO_ALLOWED_EMAILS=you@example.com,teammate@example.com

# Asset Studio — provedor de geração de imagem (Sprint 43B)
# Qual adapter usar. "fake" (padrão recomendado local/CI) gera PNGs
# determinísticos via sharp, sem custo e sem rede. "gemini" chama a API
# real — só use com ASSET_STUDIO_GEMINI_ENABLED=true e credencial válida.
ASSET_STUDIO_IMAGE_PROVIDER=fake

# Kill switch explícito pro provedor Gemini. Precisa estar "true" E ter
# GEMINI_API_KEY + GEMINI_IMAGE_MODEL configurados pro botão Generate
# aparecer com provedor "gemini" — qualquer ausência falha fechado
# (nunca cai pro fake em produção). Recomendado false por padrão.
ASSET_STUDIO_GEMINI_ENABLED=false

# Credencial da Gemini API (https://aistudio.google.com/apikey). NUNCA
# prefixar com NEXT_PUBLIC_ — só existe server-side, nunca é logada,
# nunca é persistida em jobs/attempts, nunca aparece em /dev/asset-studio.
GEMINI_API_KEY=

# Modelo Gemini de geração de imagem a usar (ex.: gemini-2.5-flash-image).
# Sem valor = provedor Gemini indisponível mesmo com chave configurada.
GEMINI_IMAGE_MODEL=
